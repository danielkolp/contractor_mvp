# App name — shown in client-facing emails (header + footer).
NEXT_PUBLIC_APP_NAME=Your Platform Name

# App URL — used to generate magic login links in client intake emails.
# In production set this to your public domain.
# In development it defaults to http://localhost:3000 automatically.
NEXT_PUBLIC_APP_URL=https://app.yourplatform.com

# Supabase
# Get these from your Supabase project dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role — used only by server-side webhook routes to bypass RLS.
# Get this from Project Settings → API → service_role key.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — transactional email for recovery follow-ups
# Sign up at https://resend.com, create an API key, and verify a sending domain.
# Without these, the app falls back to copy/manual mode and shows a clear error.
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Your Platform <followups@yourdomain.com>

# Resend inbound email — required for client replies to appear in the dashboard.
# Set up a Resend Receiving domain (Resend dashboard → Receiving) and configure
# a webhook endpoint pointing to /api/webhooks/resend/inbound with event type
# email.received. Without this, client replies go to the contractor's real email
# and are not tracked in the app.
RESEND_INBOUND_DOMAIN=reply.yourdomain.com
RESEND_WEBHOOK_SECRET=your_long_random_webhook_secret_here

# Stripe — secret key + webhook signing secret (Connect payments AND subscription billing).
# Get these from the Stripe dashboard → Developers → API keys / Webhooks.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
# Country for Connect onboarding (ISO-3166-1 alpha-2). Defaults to CA.
STRIPE_CONNECT_COUNTRY=CA

# Stripe Billing — recurring price IDs for the contractor's OWN plan.
# Create a $49/mo Pro product, a $199/mo Team product, and annual variants
# (~17% off) in the Stripe dashboard, then paste each price id here.
STRIPE_PRICE_PRO_MONTH=price_pro_monthly_id
STRIPE_PRICE_PRO_YEAR=price_pro_yearly_id
STRIPE_PRICE_TEAM_MONTH=price_team_monthly_id
STRIPE_PRICE_TEAM_YEAR=price_team_yearly_id

# Platform fee on Connect charges is set per-plan in code (Free 5% / Pro 2% / Team 1%).
# Optional per-transaction cap on the Free 5% fee, in cents (e.g. 5000 = $50).
# Leave unset for no cap.
# EUROFLO_FREE_FEE_CAP_CENTS=5000

# E2E/QA credentials
# Required only when running the QA scripts and Playwright E2E suites.
E2E_CONTRACTOR_EMAIL=contractor@example.com
E2E_CONTRACTOR_PASSWORD=your-test-password-here
